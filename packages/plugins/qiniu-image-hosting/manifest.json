{
  "id": "com.koma.qiniu-image-hosting",
  "name": "七牛云图床（内置）",
  "version": "1.0.0",
  "description": "七牛云图床服务（内置，使用激活 Key 调用 Koma 官方上传接口 komaapi.com），返回七牛云 Kodo 外链并支持时间戳防盗链，作为默认图床",
  "author": {
    "name": "Koma Team",
    "url": "https://github.com/koma-studio"
  },
  "category": "provider",
  "engine": {
    "minAppVersion": "1.0.0",
    "sdkVersion": "1.0.0"
  },
  "scopes": [
    "settings:read",
    "settings:write",
    "storage:limited",
    "network:external"
  ],
  "entry": {
    "frontend": "./dist/ui/main.js",
    "backend": "./dist/backend.js"
  },
  "providerMeta": {
    "channelType": "image-hosting",
    "capabilities": ["image-hosting"],
    "configPanel": true,
    "defaultConfig": {
      "enabled": true
    }
  }
}
