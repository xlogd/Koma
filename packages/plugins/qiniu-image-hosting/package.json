{
  "name": "koma-plugin-qiniu-image-hosting",
  "version": "1.0.0",
  "description": "Koma Plugin - Qiniu Image Hosting (Built-in)",
  "main": "dist/main.js",
  "scripts": {
    "build:ui": "esbuild src/index.tsx --bundle --format=iife --global-name=__KOMA_PLUGIN_com_koma_qiniu_image_hosting__ --outfile=dist/ui/main.js --external:react --external:antd --external:@komastudio/plugin-sdk",
    "build:backend": "esbuild src/backend.ts --bundle --format=cjs --platform=node --outfile=dist/backend.js --external:@komastudio/plugin-sdk",
    "build": "npm run build:ui && npm run build:backend"
  },
  "peerDependencies": {
    "antd": "^5.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@komastudio/plugin-sdk": "^1.0.3",
    "esbuild": "^0.19.12",
    "typescript": "^5.9.3"
  }
}
