{
  "id": "hello-mcp",
  "name": "Hello MCP",
  "version": "1.0.0",
  "description": "示例 MCP 插件 - 提供 get_time 和 echo 工具",
  "category": "mcp",
  "engine": { "minAppVersion": "1.0.0", "sdkVersion": "1.0.0" },
  "scopes": ["mcp:server", "mcp:tool"],
  "entry": { "backend": "dist/index.js" },
  "mcpMeta": {
    "transport": "internal",
    "tools": [
      { "name": "get_time", "description": "获取当前时间" },
      { "name": "echo", "description": "回显输入的文本" }
    ]
  }
}
